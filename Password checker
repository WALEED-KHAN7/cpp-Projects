#include<iostream>
#include<string>


int main(){
	std::string password;
	bool valid = false;
	
	
	std::cout<<"\t\t\t\t\t\t====================\n";
	std::cout<<" \t\t\t\t\t\t  Password Checker\n";
	std::cout<<"\t\t\t\t\t\t====================\n";
	
	while(!valid){
		
	std::cout<<"\nEnter the password:   ";
	std::cin>>password;
	valid = true;
	
	if(password.length () < 8){
		std::cout<<"\nPassword must be at least 8 characters.\n\n";
		valid = false;
	}
	
	bool hasnumber = false;
	
	for(int i=0; i<password.length(); i++){
		char c = password[i];
		
	if( c >='0' && c <='9'){
		hasnumber=true;
		break;
		}
		
	}
	
	if( hasnumber==false){
			std::cout<<"Password must include a number.\n\n";
			valid = false;
		}
		
		bool haspecial = false;
		
		for(int i=0; i<password.length(); i++){
			char c = password[i];
			
			if(!((c >='A' && c <='Z')||
			    (c >='a' && c <='z')||
				(c >='0' && c <='9'))){
					haspecial = true;
					break;
				}
			
		}
		if(haspecial == false){
			std::cout<<"Password must include a special character.\n\n";
			valid = false;
		}
		
		if(valid){
			std::cout<<"Valid Password";
		}
		else{
			std::cout<<"Please try again\n\n\n";
		}
		}
		
	}
